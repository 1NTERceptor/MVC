@model CarWorkshop.Application.CarWorkshop.Commands.EditCarWorkshopCommand

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group m-3">
                <label class="control-label">Description</label>
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Aktualna wartość:</small>
                        <div class="form-control" style="background-color: #e9ecef; padding: 0.375rem 0.75rem; border: 1px solid #dee2e6;">@Model.Description</div>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Nowa wartość:</small>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group m-3">
                <label class="control-label">About</label>
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Aktualna wartość:</small>
                        <div class="form-control" style="background-color: #e9ecef; padding: 0.375rem 0.75rem; border: 1px solid #dee2e6;">@Model.About</div>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Nowa wartość:</small>
                        <input asp-for="About" class="form-control" />
                        <span asp-validation-for="About" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group m-3">
                <label class="control-label">PhoneNumber</label>
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Aktualna wartość:</small>
                        <div class="form-control" style="background-color: #e9ecef; padding: 0.375rem 0.75rem; border: 1px solid #dee2e6;">@Model.PhoneNumber</div>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Nowa wartość:</small>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group m-3">
                <label class="control-label">Street</label>
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Aktualna wartość:</small>
                        <div class="form-control" style="background-color: #e9ecef; padding: 0.375rem 0.75rem; border: 1px solid #dee2e6;">@Model.Street</div>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Nowa wartość:</small>
                        <input asp-for="Street" class="form-control" />
                        <span asp-validation-for="Street" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group m-3">
                <label class="control-label">City</label>
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Aktualna wartość:</small>
                        <div class="form-control" style="background-color: #e9ecef; padding: 0.375rem 0.75rem; border: 1px solid #dee2e6;">@Model.City</div>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Nowa wartość:</small>
                        <input asp-for="City" class="form-control" />
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group m-3">
                <label class="control-label">PostalCode</label>
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Aktualna wartość:</small>
                        <div class="form-control" style="background-color: #e9ecef; padding: 0.375rem 0.75rem; border: 1px solid #dee2e6;">@Model.PostalCode</div>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block mb-2">Nowa wartość:</small>
                        <input asp-for="PostalCode" class="form-control" />
                        <span asp-validation-for="PostalCode" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
